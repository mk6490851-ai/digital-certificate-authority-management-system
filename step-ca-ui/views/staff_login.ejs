<!doctype html>
<html lang="en">
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Staff Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center vh-100">

<div class="card shadow-lg p-4 w-100" style="max-width: 400px;">
  <h2 class="text-center mb-4">Staff Login</h2>

  <% if (error) { %>
    <div class="alert alert-danger text-sm text-center py-2 mb-3">
      Login failed — check credentials.
    </div>
  <% } %>

  <form action="/staff/login" method="POST">
    <div class="mb-3">
      <label class="form-label">Username</label>
      <input type="text" name="username" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Password</label>
      <input type="password" name="password" class="form-control" required>
    </div>

    <div class="d-flex justify-content-between align-items-center">
      <a href="/staff/forgot" class="text-sm text-primary text-decoration-none">Forgot Password?</a>
      <button type="submit" class="btn btn-primary">Login</button>
    </div>
  </form>

  <div class="text-end mt-3">
    <small>New Staff? 
      <a href="/staff/register" class="text-decoration-none">Register</a>
    </small>
  </div>
</div>

</body>
</html>
