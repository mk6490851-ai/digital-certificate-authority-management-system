<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin Dashboard</title>
  <link rel="icon" href="/c-a.png" />

  <!-- Bootstrap & Tailwind -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body { background-color: #f8f9fa; }
    .sidebar { min-height: 100vh; transition: all 0.3s ease; }
    .sidebar.hidden { display: none !important; }
    .card-counter { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .card-counter:hover { transform: translateY(-4px); box-shadow: 0 6px 16px rgba(0,0,0,0.15); }
    .table-container { max-height: 480px; overflow-y: auto; }

    @media (max-width: 768px) {
      #hamburger { display: inline-block; }
      .sidebar {
        position: fixed; z-index: 1000; top: 0; left: 0;
        width: 220px; height: 100%;
        background: #212529; padding: 1rem;
      }
      .sidebar.hidden { left: -250px; transition: left 0.3s ease; }
    }
    @media (min-width: 769px) { #hamburger { display: none; } }
  </style>
</head>

<body class="min-h-screen">
  <div class="d-flex">
    <!-- Sidebar -->
    <div id="sidebar" class="sidebar bg-dark text-white d-flex flex-column p-3" style="width:250px;">
      <h4 class="text-center mb-4">⚙️ Admin Panel</h4>
      <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item mb-2">
          <button class="nav-link text-white w-100 active" data-bs-toggle="tab" data-bs-target="#usersTab">
            👤 Manage Users
          </button>
        </li>
        <li class="nav-item mb-2">
          <button class="nav-link text-white w-100" data-bs-toggle="tab" data-bs-target="#logsTab">
            📜 Audit Logs
          </button>
        </li>
        <li class="nav-item mt-3">
          <a href="/logout" class="btn btn-danger w-100">🚪 Logout</a>
        </li>
      </ul>
    </div>

    <!-- Main Content -->
    <div class="container-fluid p-4 flex-grow-1">
      <!-- Top Bar -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-2xl font-bold text-gray-800 mb-0">
          👑 Welcome <%= user.username %> (ADMIN)
        </h2>
        <button id="hamburger" class="btn btn-outline-dark">☰</button>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-6">
        <div class="card-counter p-4 text-center rounded-2xl bg-gradient-to-r from-blue-400 to-blue-600 text-white">
          <div class="text-3xl font-bold"><%= stats.totalUsers %></div>
          <div class="mt-2">Users</div>
        </div>
        <div class="card-counter p-4 text-center rounded-2xl bg-gradient-to-r from-green-400 to-green-600 text-white">
          <div class="text-3xl font-bold"><%= stats.admins %></div>
          <div class="mt-2">Admins</div>
        </div>
        <div class="card-counter p-4 text-center rounded-2xl bg-gradient-to-r from-yellow-400 to-yellow-600 text-white">
          <div class="text-3xl font-bold"><%= stats.managers %></div>
          <div class="mt-2">Managers</div>
        </div>
        <div class="card-counter p-4 text-center rounded-2xl bg-gradient-to-r from-indigo-400 to-indigo-600 text-white">
          <div class="text-3xl font-bold"><%= stats.certificates %></div>
          <div class="mt-2">Certificates</div>
        </div>
        <div class="card-counter p-4 text-center rounded-2xl bg-gradient-to-r from-red-400 to-red-600 text-white">
          <div class="text-3xl font-bold"><%= stats.logs %></div>
          <div class="mt-2">Logs</div>
        </div>
      </div>

      <!-- Tab Content -->
      <div class="tab-content mt-4 bg-white shadow rounded-2xl p-4">
        <!-- Manage Users -->
        <div class="tab-pane fade show active" id="usersTab">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="text-xl font-semibold">Manage Users</h3>
            <button class="btn btn-success btn-sm rounded-lg shadow" data-bs-toggle="modal" data-bs-target="#addUserModal">
              ➕ Add User
            </button>
          </div>

          <!-- 🔍 Search bar -->
          <div class="mb-3">
            <input type="text" id="userSearch" class="form-control" placeholder="Search users by username or role...">
          </div>

          <% if (!allUsers || allUsers.length === 0) { %>
            <p class="text-gray-500">No users found.</p>
          <% } else { %>
            <div class="table-container">
              <table class="table table-striped table-hover align-middle text-sm" id="usersTable">
                <thead class="table-light sticky-top">
                  <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created On</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% allUsers.forEach(u => { %>
                    <tr>
                      <td><%= u.username %></td>
                      <td><span class="badge bg-secondary"><%= u.role %></span></td>
                      <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                      <td class="text-end">
                        <button class="btn btn-sm btn-primary me-2"
                          onclick="openRoleModal('<%= u.username %>','<%= u.role %>')">
                          ✏️ Role
                        </button>
                        <form action="/users/delete" method="POST" class="d-inline">
                          <input type="hidden" name="username" value="<%= u.username %>">
                          <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Are you sure you want to delete this user?');">
                            🗑️ Delete
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- Audit Logs -->
        <div class="tab-pane fade" id="logsTab">
          <h3 class="text-xl font-semibold text-gray-700 mb-4">Audit Logs</h3>

          <!-- 🔍 Search bar -->
          <div class="mb-3">
            <input type="text" id="logSearch" class="form-control" placeholder="Search logs by user, action, or details...">
          </div>

          <div class="table-container">
            <table class="table table-striped table-hover align-middle text-sm" id="logsTable">
              <thead class="table-light sticky-top">
                <tr>
                  <th>User</th>
                  <th>Action</th>
                  <th>Details</th>
                  <th>Timestamp</th>
                </tr>
              </thead>
              <tbody>
                <% if (logs && logs.length > 0) { %>
                  <% logs.forEach(log => { %>
                    <tr>
                      <td><%= log.username %></td>
                      <td><%= log.action %></td>
                      <td><%= log.details %></td>
                      <td><%= new Date(log.timestamp).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center text-gray-500">No audit logs available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <footer class="text-center text-gray-500 text-sm mt-4">
          &copy; <%= new Date().getFullYear() %> Digital Certificate Authority. All rights reserved.
        </footer>
      </div>
    </div>
  </div>

  <!-- Add User Modal -->
  <div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content rounded-2xl shadow">
        <div class="modal-header">
          <h5 class="modal-title">➕ Add New User</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="POST" action="/users/add">
          <div class="modal-body">
            <input name="username" class="form-control mb-2" placeholder="Username" required>
            <input name="email" type="email" class="form-control mb-2" placeholder="Email" required>
            <input name="phone" class="form-control mb-2" placeholder="Phone" required>
            <input name="password" type="password" class="form-control mb-2" placeholder="Password" required>
            <select name="role" class="form-select mb-2" required>
              <option value="USER">User</option>
              <option value="CA_MANAGER">Manager</option>
              <option value="ADMIN">Admin</option>
            </select>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success" onclick="alert('User added successfully!')">Add</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Change Role Modal -->
  <div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content rounded-2xl shadow">
        <div class="modal-header">
          <h5 class="modal-title">✏️ Change Role for <span id="modalUsername"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="POST" action="/users/change-role">
          <div class="modal-body">
            <input type="hidden" id="modalUsernameInput" name="username" />
            <select id="modalRoleSelect" name="role" class="form-select">
              <option value="USER">User</option>
              <option value="CA_MANAGER">CA Manager</option>
              <option value="ADMIN">Admin</option>
            </select>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary" onclick="alert('Role updated successfully!')">Update Role</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Sidebar toggle for mobile
    document.getElementById('hamburger').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('hidden');
    });

    // Open modal for changing role
    function openRoleModal(username, role) {
      document.getElementById("modalUsername").innerText = username;
      document.getElementById("modalUsernameInput").value = username;
      document.getElementById("modalRoleSelect").value = role;
      let modal = new bootstrap.Modal(document.getElementById("roleModal"));
      modal.show();
    }

    // 🔍 Search filter for Manage Users
    document.getElementById("userSearch").addEventListener("keyup", function() {
      const filter = this.value.toLowerCase();
      const rows = document.querySelectorAll("#usersTable tbody tr");
      rows.forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(filter) ? "" : "none";
      });
    });

    // 🔍 Search filter for Audit Logs
    document.getElementById("logSearch").addEventListener("keyup", function() {
      const filter = this.value.toLowerCase();
      const rows = document.querySelectorAll("#logsTable tbody tr");
      rows.forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(filter) ? "" : "none";
      });
    });
  </script>
</body>
</html>
