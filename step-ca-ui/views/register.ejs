<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>User Registration</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 d-flex align-items-center justify-content-center vh-100">

  <div class="card shadow-lg p-4 w-100" style="max-width: 650px;">
    <h2 class="text-center mb-4 text-2xl font-bold">Create Account</h2>

    <form action="/register" method="POST">
      <div class="row g-3">
        <!-- Left side -->
        <div class="col-md-6">
          <!-- Username -->
          <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" placeholder="Enter your username" required>
          </div>

          <!-- Phone -->
          <div class="mb-3">
            <label class="form-label">Phone</label>
            <input type="text" name="phone" class="form-control" placeholder="03XXXXXXXXX" required>
          </div>

          <!-- Email -->
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="example@email.com" required>
          </div>
        </div>

        <!-- Right side -->
        <div class="col-md-6">
          <!-- Password -->
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Enter password" required>
          </div>

          <!-- Confirm Password -->
          <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password" required>
          </div>
        </div>
      </div>

      <!-- Submit button -->
      <div class="d-grid mt-3">
        <button type="submit" class="btn btn-primary">Register</button>
      </div>
    </form>

    <!-- Already Registered link -->
    <div class="text-center mt-3">
      <small>Already registered? 
        <a href="/login" class="text-decoration-none text-blue-600">Login</a>
      </small>
    </div>
  </div>

</body>
</html>
