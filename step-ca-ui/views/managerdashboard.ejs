<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Manager Dashboard</title>
  <link rel="icon" href="/c-a.png" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    body {
      margin:0; min-height:100vh; background:#f5f7fa;
      font-family:Segoe UI,sans-serif; color:#333;
      display:flex; justify-content:center; padding:20px;
    }
    .box {
      width:100%; max-width:1200px; background:#fff;
      padding:24px; border-radius:12px;
      box-shadow:0 10px 30px rgba(0,0,0,0.1);
      display:flex; flex-direction:column; justify-content:space-between;
    }
    header {
      display:flex; justify-content:space-between; align-items:center;
      margin-bottom:20px;
    }
    h2 { margin:0; font-size:22px; font-weight:700; color:#222 }
    .logout-btn {
      background:#ef4444; border:none; color:#fff;
      padding:8px 16px; border-radius:6px; cursor:pointer;
      font-size:14px; font-weight:500;
    }
    .logout-btn:hover { background:#dc2626 }

    .cards {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:20px; margin-bottom:20px
    }
    .card {
      padding:20px; border-radius:12px; color:#fff; font-weight:600;
      cursor:pointer; display:flex; flex-direction:column;
      justify-content:space-between; position:relative; overflow:hidden;
      box-shadow:0 5px 15px rgba(0,0,0,0.2); transition:.2s
    }
    .card:hover { transform:translateY(-6px); box-shadow:0 8px 20px rgba(0,0,0,0.25) }
    .card .number { font-size:28px; font-weight:700; margin-bottom:8px }
    .card .title { font-size:16px }
    .card .more { margin-top:10px; font-size:14px; opacity:0.9 }
    .card .icon { position:absolute; bottom:-20px; right:-20px; font-size:80px; opacity:0.15 }

    /* Colors */
    .blue{background:linear-gradient(135deg,#36d1dc,#5b86e5)}
    .green{background:linear-gradient(135deg,#11998e,#38ef7d)}
    .yellow{background:linear-gradient(135deg,#f7971e,#ffd200)}
    .red{background:linear-gradient(135deg,#cb2d3e,#ef473a)}
    .dark{background:linear-gradient(135deg,#232526,#414345)}
    .pink{background:linear-gradient(135deg,#f857a6,#ff5858)}
    .purple{background:linear-gradient(135deg,#7b4397,#dc2430)}

    table {
      width:100%; border-collapse:collapse; margin-top:12px; background:#fff;
      border-radius:10px; overflow:hidden; box-shadow:0 5px 15px rgba(0,0,0,0.05)
    }
    th,td { padding:12px; text-align:left; font-size:14px }
    th {
      background:#f1f3f6; color:#333;
      text-transform:uppercase; font-size:12px; letter-spacing:0.5px
    }
    tr:nth-child(even){background:#fafafa}
    tr:hover{background:#f5faff}
    button {
      padding:8px 14px; border-radius:6px; border:none;
      background:#007bff; color:#fff; cursor:pointer;
      font-size:13px; font-weight:500; transition:.2s
    }
    button:hover{background:#0056b3}

    .section { display:none; margin-top:20px }

    .modal {
      display:none; position:fixed; z-index:1000;
      left:0; top:0; width:100%; height:100%;
      background:rgba(0,0,0,0.5); align-items:center; justify-content:center
    }
    .modal-content {
      background:#fff; color:#333; padding:24px; border-radius:12px;
      width:530px; max-width:90%;
      box-shadow: 8px 25px rgba(0,0,0,0.2);
      animation:fadeIn .3s ease
    }
    .close {
      float:right; font-size:22px; font-weight:bold;
      cursor:pointer; color:#888
    }
    .close:hover { color:#000 }
    footer {
      text-align:center; margin-top:30px; font-size:13px; color:#666;
    }
    @keyframes fadeIn {
      from{opacity:0;transform:translateY(-20px)}
      to{opacity:1;transform:translateY(0)}
    }
  </style>
</head>
<body>
  <div class="box">
    <header>
      <h2>🚀 Welcome <%= user.username %> (CA Manager)</h2>
      <form action="/logout" method="POST">
        <a href="/logout" 
           style="display:inline-block; background:#007bff; color:#fff; 
                  text-align:center; padding:10px 20px; border-radius:6px; 
                  font-weight:bold; text-decoration:none;">
          🚪 Logout
        </a>
      </form>
    </header>

    <!-- Cards -->
    <div class="cards">
      <div class="card blue" onclick="toggleSection('caSection')">
        <div class="number"><%= caInfo.length %></div>
        <div class="title">Certificate Authorities</div>
        <div class="more">More info →</div>
        <div class="icon">🛡️</div>
      </div>
      <div class="card green" onclick="toggleSection('pendingSection')">
        <div class="number"><%= pendingRequests.length %></div>
        <div class="title">Pending Requests</div>
        <div class="more">More info →</div>
        <div class="icon">📩</div>
      </div>
      <div class="card yellow" onclick="toggleSection('acceptedSection')">
        <div class="number"><%= acceptedRequests.length %></div>
        <div class="title">Accepted Requests</div>
        <div class="more">More info →</div>
        <div class="icon">✅</div>
      </div>
      <div class="card pink" onclick="toggleSection('rejectedSection')">
        <div class="number"><%= rejectedRequests.length %></div>
        <div class="title">Rejected Requests</div>
        <div class="more">More info →</div>
        <div class="icon">❌</div>
      </div>
      <div class="card red" onclick="toggleSection('revokedSection')">
        <div class="number"><%= revokedCertificates.length %></div>
        <div class="title">Revoked Certificates</div>
        <div class="more">More info →</div>
        <div class="icon">⛔</div>
      </div>
      <div class="card dark" onclick="toggleSection('renewedSection')">
        <div class="number"><%= renewedCertificates.length %></div>
        <div class="title">Renewed Certificates</div>
        <div class="more">More info →</div>
        <div class="icon">♻️</div>
      </div>
      <div class="card purple" onclick="toggleSection('allSection')">
        <div class="number"><%= certificates.length %></div>
        <div class="title">All Certificates</div>
        <div class="more">More info →</div>
        <div class="icon">📜</div>
      </div>
      <div class="card blue" onclick="toggleSection('messagesSection')">
        <div class="number"><%= messages.length %></div>
        <div class="title">Messages</div>
        <div class="more">View →</div>
        <div class="icon">💬</div>
      </div>
    </div>

    <!-- Sections -->
    <div id="caSection" class="section">
      <h3>Manage Certificate Authorities</h3>
      <table>
        <thead><tr><th>CA Name</th><th>Created On</th><th>Expiry</th><th>Action</th></tr></thead>
        <tbody>
          <% caInfo.forEach(ca => { %>
            <tr>
              <td><%= ca.name %></td>
              <td><%= ca.createdOn %></td>
              <td><%= ca.expiryOn %></td>
              <td><button onclick="openCAModal('<%= String(ca.name).replace(/\s+/g,'') %>')">View</button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div id="pendingSection" class="section">
      <h3>Pending Certificate Requests</h3>
      <% if (!pendingRequests.length) { %>
        <p>No pending requests.</p>
      <% } else { %>
        <table>
          <thead><tr><th>ID</th><th>User</th><th>Subject</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% pendingRequests.forEach(r => { %>
              <tr>
                <td><%= r.id %></td>
                <td><%= r.user %></td>
                <td><%= r.subject %></td>
                <td><%= r.status %></td>
                <td>
                  <form method="POST" action="/requests/issue/<%= r.id %>" style="display:inline"><button>Issue</button></form>
                  <form method="POST" action="/requests/reject/<%= r.id %>" style="display:inline"><button>Reject</button></form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="acceptedSection" class="section">
      <h3>Accepted Requests</h3>
      <% if (!acceptedRequests.length) { %>
        <p>No accepted requests.</p>
      <% } else { %>
        <table>
          <thead><tr><th>ID</th><th>User</th><th>Subject</th><th>Status</th></tr></thead>
          <tbody>
            <% acceptedRequests.forEach(r => { %>
              <tr><td><%= r.id %></td><td><%= r.user %></td><td><%= r.subject %></td><td><%= r.status %></td></tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="rejectedSection" class="section">
      <h3>Rejected Requests</h3>
      <% if (!rejectedRequests.length) { %>
        <p>No rejected requests.</p>
      <% } else { %>
        <table>
          <thead><tr><th>ID</th><th>User</th><th>Subject</th><th>Status</th></tr></thead>
          <tbody>
            <% rejectedRequests.forEach(r => { %>
              <tr><td><%= r.id %></td><td><%= r.user %></td><td><%= r.subject %></td><td><%= r.status %></td></tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="renewedSection" class="section">
      <h3>Renewed Certificates</h3>
      <% if (!renewedCertificates.length) { %>
        <p>No renewed certificates.</p>
      <% } else { %>
        <table>
          <thead><tr><th>File</th><th>Owner</th><th>Status</th><th>Expiry</th></tr></thead>
          <tbody>
            <% renewedCertificates.forEach(cert => { %>
              <tr><td><%= cert.fileName %></td><td><%= cert.owner %></td><td><%= cert.status %></td><td><%= cert.expiryDate %></td></tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="revokedSection" class="section">
      <h3>Revoked Certificates</h3>
      <% if (!revokedCertificates.length) { %>
        <p>No revoked certificates.</p>
      <% } else { %>
        <table>
          <thead><tr><th>File</th><th>Owner</th><th>Status</th><th>Expiry</th></tr></thead>
          <tbody>
            <% revokedCertificates.forEach(cert => { %>
              <tr><td><%= cert.fileName %></td><td><%= cert.owner %></td><td><%= cert.status %></td><td><%= cert.expiryDate %></td></tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="allSection" class="section">
      <h3>All Certificates</h3>
      <% if (!certificates.length) { %>
        <p>No certificates.</p>
      <% } else { %>
        <table>
          <thead><tr><th>File</th><th>Owner</th><th>Status</th><th>Expiry</th><th>Actions</th></tr></thead>
          <tbody>
            <% certificates.forEach(cert => { %>
              <tr>
                <td><%= cert.fileName %></td>
                <td><%= cert.owner %></td>
                <td><%= cert.status %></td>
                <td><%= cert.expiryDate %></td>
                <td>
     <form method="POST" action="/certificates/revoke/<%= cert.fileName %>" style="display:inline"><button>Revoke</button></form>
                  <form method="POST" action="/certificates/renew/<%= cert.fileName %>" style="display:inline"><button>Renew</button></form>
                  <button type="button" onclick="openCertModal('<%= cert.fileName %>')">View</button>
                </td>
                </td>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="messagesSection" class="section">
      <h3>💬 Support Messages</h3>
      <% if (!messages.length) { %>
        <p>No support messages.</p>
      <% } else { %>
        <table>
          <thead><tr><th>User</th><th>Message</th><th>Sent At</th><th>Reply</th></tr></thead>
          <tbody>
            <% messages.forEach(m => { %>
              <tr>
                <td><%= m.user %></td>
                <td><%= m.message %></td>
                <td><%= m.created_at %></td>
                <td>
                  <form method="POST" action="/support/reply/<%= m.id %>">
                    <input type="text" name="reply" placeholder="Write reply..." required />
                    <button>Reply</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <footer>
      © <%= new Date().getFullYear() %> Certificate Authority System. All rights reserved.
    </footer>
  </div>

  <!-- Certificate Modal -->
  <div id="certModal" class="modal">
    <div class="modal-content">
      <span class="close" onclick="closeCertModal()">&times;</span>
      <h3>Certificate Details</h3>
      <p><b>Issued To:</b> <span id="certIssuedTo"></span></p>
      <p><b>Issuer:</b> <span id="certIssuer"></span></p>
      <p><b>Serial:</b> <span id="certSerial"></span></p>
      <p><b>Issue Date:</b> <span id="certIssueDate"></span></p>
      <p><b>Expiry Date:</b> <span id="certExpiryDate"></span></p>
    </div>
  </div>

  <!-- CA Modals -->
  <% caInfo.forEach(ca => { %>
    <div id="caModal-<%= String(ca.name).replace(/\s+/g,'') %>" class="modal">
      <div class="modal-content">
        <span class="close" onclick="closeCAModal('<%= String(ca.name).replace(/\s+/g,'') %>')">&times;</span>
        <h3>Certificate Authority Details</h3>
        <p><b>Name:</b> <%= ca.name %></p>
        <p><b>Issuer:</b> <%= ca.issuer %></p>
        <p><b>Status:</b> <%= ca.status %></p>
        <p><b>Serial:</b> <%= ca.serial %></p>
        <p><b>Fingerprint:</b> <%= ca.fingerprint %></p>
        <p><b>Created On:</b> <%= ca.createdOn %></p>
        <p><b>Expiry:</b> <%= ca.expiryOn %></p>
      </div>
    </div>
  <% }) %>

<script>
  const certData = <%- JSON.stringify(certificates) %>;

  function formatDateTime(dateStr) {
    if (!dateStr) return "N/A";
    const d = new Date(dateStr);
    return d.toLocaleString("en-GB", {
      day: "numeric", month: "short", year: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: true
    });
  }

  function toggleSection(id) {
    document.querySelectorAll(".section").forEach(sec => sec.style.display = "none");
    const el = document.getElementById(id);
    if (el) el.style.display = "block";
  }

  function openCertModal(fileName) {
    const cert = certData.find(c => c.fileName === fileName);
    if (!cert) return Swal.fire("Not found", "Certificate not found", "error");
    document.getElementById("certIssuedTo").innerText = cert.owner || "N/A";
    document.getElementById("certIssuer").innerText = cert.issuer || "N/A";
    document.getElementById("certSerial").innerText = cert.serial || "N/A";
    document.getElementById("certIssueDate").innerText = formatDateTime(cert.issued_at);
    document.getElementById("certExpiryDate").innerText = formatDateTime(cert.expiryDate);
    document.getElementById("certModal").style.display = "flex";
  }
  function closeCertModal(){document.getElementById("certModal").style.display="none"}

  function openCAModal(name){document.getElementById("caModal-"+name).style.display="flex"}
  function closeCAModal(name){document.getElementById("caModal-"+name).style.display="none"}
</script>
<script>
  (function() {
    const params = new URLSearchParams(window.location.search);
    const status = params.get("status");
    if (!status) return;
    switch (status) {
      case "issued":
        alert("✅ Certificate has been successfully issued!");
        break;
      case "rejected":
        alert("❌ Certificate request has been rejected.");
        break;
      case "replied":
        alert("📩 Your reply has been sent successfully!");
        break;
      case "renewed":
        alert("🔄 Certificate has been renewed successfully!");
        break;
      case "revoked":
        alert("⚠️ Certificate has been revoked.");
        break;
      default:
        break;
    }
  const url = new URL(window.location);
    url.searchParams.delete("status");
    window.history.replaceState({}, document.title, url.toString());
  })();
  </script>
</body>
</html>
